{
  "manifest_version": 3,
  "name": "Page RAG Q&A",
  "version": "0.1.0",
  "description": "Ask grounded questions about the current page and save structured notes.",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
